<?xml version="1.0" encoding="UTF-8"?>
<!--
  模板：股权变动前后图（equity-change-before-after）
  适用场景：S-09 单次股权变动前后对比；S-10 多次股权变动图；MA-09 交易前后结构对比图
  必要输入字段：entities[].role, relations[].label, relations[].percentage, events[].date
  默认布局：左侧交易前，右侧交易后，中间箭头标注变动事项
  可变参数：股东数、是否显示注册资本变化、是否显示实际控制路径
-->
<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="股权变动前后对比图"
      style="text;fontSize=24;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1a1a2e;"
      vertex="1" parent="1">
      <mxGeometry x="60" y="20" width="980" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="beforeFrame" value="变动前"
      style="swimlane;startSize=30;fillColor=#F5F5F5;strokeColor=#BDBDBD;strokeWidth=2;fontSize=14;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="80" y="100" width="360" height="300" as="geometry"/>
    </mxCell>
    <mxCell id="afterFrame" value="变动后"
      style="swimlane;startSize=30;fillColor=#F5F5F5;strokeColor=#BDBDBD;strokeWidth=2;fontSize=14;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="620" y="100" width="360" height="300" as="geometry"/>
    </mxCell>
    <mxCell id="bShareA" value="股东 A&#10;60%" style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1f77b4;fontSize=12;" vertex="1" parent="1"><mxGeometry x="130" y="160" width="110" height="54" as="geometry"/></mxCell>
    <mxCell id="bShareB" value="股东 B&#10;40%" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FF8C00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="280" y="160" width="110" height="54" as="geometry"/></mxCell>
    <mxCell id="bCompany" value="目标公司" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#1f77b4;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="190" y="280" width="140" height="60" as="geometry"/></mxCell>
    <mxCell id="aShareA" value="股东 A&#10;30%" style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1f77b4;fontSize=12;" vertex="1" parent="1"><mxGeometry x="660" y="160" width="110" height="54" as="geometry"/></mxCell>
    <mxCell id="aShareB" value="股东 B&#10;40%" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FF8C00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="785" y="160" width="110" height="54" as="geometry"/></mxCell>
    <mxCell id="aShareC" value="受让方 C&#10;30%" style="rounded=1;whiteSpace=wrap;fillColor=#FDECEA;strokeColor=#C0392B;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="790" y="250" width="130" height="54" as="geometry"/></mxCell>
    <mxCell id="aCompany" value="目标公司" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#1f77b4;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="705" y="330" width="140" height="60" as="geometry"/></mxCell>
    <mxCell id="change" value="股权转让/增资&#10;（待补充日期、价款）" style="rounded=1;whiteSpace=wrap;fillColor=#FDECEA;strokeColor=#C0392B;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="460" y="220" width="140" height="64" as="geometry"/></mxCell>
    <mxCell id="be1" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#333333;edgeStyle=orthogonalEdgeStyle;" edge="1" source="bShareA" target="bCompany" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="be2" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#333333;edgeStyle=orthogonalEdgeStyle;" edge="1" source="bShareB" target="bCompany" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ae1" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#333333;edgeStyle=orthogonalEdgeStyle;" edge="1" source="aShareA" target="aCompany" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ae2" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#333333;edgeStyle=orthogonalEdgeStyle;" edge="1" source="aShareB" target="aCompany" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ae3" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#C0392B;edgeStyle=orthogonalEdgeStyle;" edge="1" source="aShareC" target="aCompany" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ce1" value="" style="endArrow=classic;strokeWidth=3;strokeColor=#C0392B;edgeStyle=orthogonalEdgeStyle;" edge="1" source="bShareA" target="change" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ce2" value="" style="endArrow=classic;strokeWidth=3;strokeColor=#C0392B;edgeStyle=orthogonalEdgeStyle;" edge="1" source="change" target="aShareC" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>
