# Agent Email 环境配置
# 复制为 .env 并填入实际值。真实 .env 已被根 .gitignore 忽略（**/.env）。

# ═══ 默认后端 ═══
# claw    网易 ClawEmail（@clawemail/mail-cli，API Key 认证，零 token）
# agently 腾讯 Agent Mail / QQ 邮箱（@tencent-qqmail/agently-cli，OAuth 认证）
# 切换：export MAIL_PROVIDER=agently  即可让所有 mail_* 走腾讯
MAIL_PROVIDER=claw

# ═══ 网易 ClawEmail 字段（MAIL_PROVIDER=claw 时使用）═══
# Agent 邮箱地址
AGENT_EMAIL=your-agent@claw.163.com
# 发件人显示名称（对方收到邮件时看到的名称；claw_send/mail_send 据此构造 --from）
DISPLAY_NAME="Your Agent Name"
# 邮箱前缀（用于 clawemail 子邮箱管理）
CLAW_PREFIX=your-agent
# mail-cli Profile 名（默认 default；多账号用 --profile 区分）
CLAW_PROFILE=default
# 文件夹 ID（网易约定：1=收件箱, 3=已发送）
INBOX_FID=1
SENT_FID=3

# ═══ 腾讯 Agent Mail 字段（MAIL_PROVIDER=agently 时使用）═══
# agently-cli 的 OAuth 凭据由 CLI 自管（agently_login 后存本机），.env 不持有。
# AGENTLY_EMAIL 仅作记录用，mail_login/agently_login +me 会返回实际地址。
# AGENTLY_EMAIL=your-agent@qq.com

# ═══ 常用联系人（发任务 / 收发材料时直接引用，两家后端通用）═══
# 格式: AGENT_<NAME> 或 CONTACT_<NAME>
# source scripts/mail-ops.sh 后即可 $AGENT_MANUS / $CONTACT_163 引用
# AGENT_MANUS=manus@manus.bot
# CONTACT_163=you@163.com
# CONTACT_GMAIL=you@gmail.com
