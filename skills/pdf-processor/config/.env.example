# 外部 API 调用顺序（auto 模式）
# 该顺序就是 API 尝试顺序；支持值：mineru, paddle（逗号分隔）
OCR_API_ORDER="paddle,mineru"

# MinerU API（可选）
MINERU_API_BASE="https://mineru.net/api/v4"
MINERU_API_TOKEN="your_mineru_token_here"
# 可选：部分网关需要额外 user token 头
MINERU_USER_TOKEN=""
# 注意：MinerU API Token 约 90 天（3 个月）有效，过期后需重新申请
# 申请/更新地址：https://mineru.net/apiManage/token

# 外部 PaddleOCR API（可选）
PADDLE_OCR_API_ENDPOINT="https://your-aistudio-app.com/ocr"
PADDLE_OCR_API_KEY="your_paddle_token_here"

# 兼容别名（可选）：如果你已经使用旧变量，可继续保留
# API_URL="https://your-aistudio-app.com/ocr"
# TOKEN="your_token_here"
# MINERU_API_BASE_URL="https://mineru.net"
# MINERU_BASE_URL="https://mineru.net"
# MINERU_TOKEN="your_mineru_token_here"
